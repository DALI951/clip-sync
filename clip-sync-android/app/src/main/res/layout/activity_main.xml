<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ClipSync"
        android:textColor="#818CF8"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/pcNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#34D399"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening for PC..."
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/toggleBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Start Sync"
        android:textColor="#E2E8F0"
        android:backgroundTint="#334155"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Clipboard History"
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/clipList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
